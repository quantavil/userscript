{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noDoubleEquals": "off",
        "noGlobalIsNan": "off",
        "noConfusingVoidType": "off"
      },
      "complexity": {
        "noForEach": "off",
        "useOptionalChain": "off"
      },
      "style": {
        "useConst": "off",
        "noNonNullAssertion": "off",
        "useTemplate": "off",
        "noUselessElse": "off"
      }
    }
  },
  "formatter": {
    "enabled": false
  }
}
